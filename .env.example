# Copy to .env and fill in for local development. Never commit the real .env.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=asx_risk
DB_USER=postgres
DB_PASSWORD=YourStrongPassword
# AWS only: ARN of a Secrets Manager secret containing either a plaintext
# password or JSON with a `password` field. It takes precedence over DB_PASSWORD.
DB_SECRET_ARN=

# Optional cross-check macro data source
FRED_API_KEY=

# Optional: path to a full ASX200 constituents CSV (ticker,name,sector,industry)
ASX_TICKERS_FILE=

AWS_REGION=ap-southeast-2
S3_BUCKET=asx-risk-data-lake
